{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["name", "email", "role"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "A user's KBO ranking prediction",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "message": { "type": "string" },
        "rankings": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "score": { "type": "number" },
        "correctCount": { "type": "integer" },
        "weightedPoints": { "type": "integer" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "rankings", "status", "userId", "createdAt", "correctCount", "weightedPoints"]
    },
    "CurrentRanking": {
      "title": "CurrentRanking",
      "description": "The current official KBO rankings",
      "type": "object",
      "properties": {
        "rankings": { 
          "type": "array",
          "items": { 
            "type": "object",
            "properties": {
              "teamId": { "type": "string" },
              "rank": { "type": "integer" }
            },
            "required": ["teamId", "rank"]
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rankings", "updatedAt"]
    },
    "HistoricalRanking": {
      "title": "HistoricalRanking",
      "description": "Historical KBO rankings for trend analysis",
      "type": "object",
      "properties": {
        "rankings": { 
          "type": "array",
          "items": { 
            "type": "object",
            "properties": {
              "teamId": { "type": "string" },
              "rank": { "type": "integer" }
            },
            "required": ["teamId", "rank"]
          }
        },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deleted": { "type": "boolean" }
      },
      "required": ["rankings", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Ranking predictions"
    },
    "/settings/currentRanking": {
      "schema": "CurrentRanking",
      "description": "Current official rankings"
    },
    "/historicalRankings/{rankingId}": {
      "schema": "HistoricalRanking",
      "description": "Historical rankings records"
    }
  }
}
