rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - name: string
    //   - email: string
    //   - role: string (admin, user)
    //
    // Collection: predictions
    // Document ID: predictionId
    // Fields:
    //   - name: string
    //   - message: string
    //   - rankings: list of strings
    //   - status: string (pending, approved)
    //   - score: number
    //   - correctCount: number
    //   - weightedPoints: number
    //   - userId: string
    //   - createdAt: timestamp
    //
    // Collection: settings
    // Document ID: currentRanking
    // Fields:
    //   - rankings: list of objects { teamId: string, rank: number }
    //   - updatedAt: timestamp
    //
    // Collection: visitors
    // Document ID: stats
    // Fields:
    //   - count: number
    //
    // Collection: historicalRankings
    // Document ID: rankingId
    // Fields:
    //   - rankings: list of objects { teamId: string, rank: number }
    //   - date: timestamp
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email.matches("(?i)cerenis\\.injung@gmail\\.com"));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['name', 'email', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['name', 'rankings', 'status', 'createdAt', 'correctCount', 'weightedPoints']) &&
             data.keys().hasOnly(['name', 'message', 'rankings', 'status', 'score', 'correctCount', 'weightedPoints', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (data.message == null || (data.message is string && data.message.size() < 500)) &&
             data.rankings is list && data.rankings.size() == 10 &&
             data.status in ['pending', 'approved'] &&
             (data.score == null || data.score is number) &&
             data.correctCount is number &&
             data.weightedPoints is number &&
             (data.userId == null || data.userId is string) &&
             data.createdAt is timestamp;
    }

    function isValidCurrentRanking(data) {
      return data.keys().hasOnly(['rankings', 'updatedAt']) &&
             data.rankings is list && data.rankings.size() == 10 &&
             data.updatedAt is timestamp;
    }

    function isValidHistoricalRanking(data) {
      return data.keys().hasAll(['rankings', 'date', 'createdAt']) &&
             data.keys().hasOnly(['rankings', 'date', 'createdAt', 'deleted']) &&
             data.rankings is list && data.rankings.size() == 10 &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             (!('deleted' in data) || data.deleted is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /predictions/{predictionId} {
      allow read: if (resource.data.status == 'approved') || (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow create: if isValidPrediction(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidPrediction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/currentRanking {
      allow read: if true;
      allow write: if isAdmin() && isValidCurrentRanking(request.resource.data);
    }

    match /visitors/stats {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['count']) &&
                     request.resource.data.count == 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count']) &&
                     request.resource.data.count is number &&
                     request.resource.data.count == resource.data.count + 1;
    }

    match /historicalRankings/{rankingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidHistoricalRanking(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
